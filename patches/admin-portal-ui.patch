@@ -0,0 +1,52 @@
+import {Icon, Tooltip} from '@dagster-io/ui-components';
+import {useContext, useEffect, useState} from 'react';
+
+import {NavCollapseContext} from './NavCollapseProvider';
+import {NavItemContent} from './NavItemContent';
+import styles from './css/MainNavigation.module.css';
+
+// Calls /api/me to check if the current user has any admin portal permission.
+async function fetchAdminAccess(): Promise<boolean> {
+  try {
+    const resp = await fetch('/api/me', {credentials: 'same-origin'});
+    if (!resp.ok) return false;
+    const data = await resp.json();
+    return !!data.hasAnyAdminPermission;
+  } catch {
+    return false;
+  }
+}
+
+export const AdminPortalItem = () => {
+  const {isCollapsed} = useContext(NavCollapseContext);
+  const [hasAccess, setHasAccess] = useState(false);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    let cancelled = false;
+    fetchAdminAccess().then((v) => {
+      if (!cancelled) {
+        setHasAccess(v);
+        setLoading(false);
+      }
+    });
+    return () => {
+      cancelled = true;
+    };
+  }, []);
+
+  if (loading || !hasAccess) {
+    return null;
+  }
+
+  // Use a plain <a> tag (not NavLink) because /admin is a server-rendered
+  // Jinja2 route, not a React SPA route. NavLink would try to handle it
+  // client-side, causing a redirect or 404.
+  return (
+    <Tooltip content="Admin Portal" placement="right" canShow={isCollapsed}>
+      <a href="/admin" className={styles.link}>
+        <NavItemContent icon={<Icon name="admin" />} label="Admin" collapsed={isCollapsed} />
+      </a>
+    </Tooltip>
+  );
+};
